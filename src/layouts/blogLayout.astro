---
import {reference} from "astro:content";
import BaseLayout from './baseLayout.astro';
import BlogViewOption from '../components/blogViewOption.astro';

interface Props {
    title: string;
    description: string;
    createdAt: date;
    updatedAt?: date | undefined;
    heroImage?: {
        src: string,
        alt: string
    } | undefined ;
    tags: string[];
    footnote?: string | undefined;
}

const { title, description, createdAt, updatedAt, heroImage, tags, relatedBlogs, footnote } = Astro.props;
---
<BaseLayout title={title} description={description}>
    <div class="container" x-data :class="!$store.isComfy.on && 'detail'">
        <h1 style="line-height: 0;">{title}</h1>
        <h5>{description}</h5>
        <BlogViewOption title={title} description={description} />
        <div class="container raise concave detail" :style="{ '--line-height': $store.lineHeight.at+'rem' }">
            <slot/>

        </div>
    </div>
</BaseLayout>